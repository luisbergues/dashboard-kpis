{
  "rules": {
    ".read": false,
    ".write": false,

    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      "$uid": {
        ".read": "auth.uid === $uid",

        ".write": "(auth.uid === $uid && !data.exists()) || (root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved')",
        ".validate": "!(auth.uid === $uid && !data.exists()) || (newData.hasChildren(['email', 'designerName', 'requestedRole', 'createdAt']) && !newData.hasChild('role') && !newData.hasChild('status'))",

        "email":        { ".write": "auth.uid === $uid && !data.exists()" },
        "designerName": { ".write": "auth.uid === $uid" },
        "createdAt":    { ".write": "auth.uid === $uid && !data.exists()" },

        "requestedRole": {
          ".write": "auth.uid === $uid && !data.exists()",
          ".validate": "newData.isString() && newData.val().matches(/^(engineer|engineer_nester|administrative|designer)$/)"
        },

        "role": {
          ".write": "root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved'",
          ".validate": "newData.isString() && newData.val().matches(/^(engineer|engineer_nester|administrative|designer)$/)"
        },

        "status": {
          ".write": "root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved'",
          ".validate": "newData.isString() && newData.val().matches(/^(pending|approved|rejected)$/)"
        },

        "readNotes": { "$so": { ".write": "auth.uid === $uid" } }
      }
    },

    "project_overrides": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "project_stages": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "project_qa_checklist": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "weekly_history": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "deleted_projects": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },

    "project_kanban_state": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'engineer_nester' || root.child('users').child(auth.uid).child('role').val() === 'engineer-admin')"
    },
    "project_kanban_order": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && (root.child('users').child(auth.uid).child('role').val() === 'engineer_nester' || root.child('users').child(auth.uid).child('role').val() === 'engineer-admin')"
    },

    "allowed_designers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "designer_contacts": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "root.child('users').child(auth.uid).child('role').val() === 'engineer-admin' && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "calendar_notes": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "project_notes": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "project_designers": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "designer_performance_projects": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "engineering_checks": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "nesting_checks": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "project_collaborators": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "project_history": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "project_materials": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "weekly_engineer_kpi": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved' && root.child('users').child(auth.uid).child('role').val() !== 'designer'"
    },
    "essData": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "ipData": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "logbookData": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "firebase_cache": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },

    "archive": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },
    "archive_lock": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'",
      ".write": "auth != null && root.child('users').child(auth.uid).child('status').val() === 'approved'"
    },

    "$other": {
      ".read": false,
      ".write": false
    }
  }
}
