rules_version = '2';

// The only thing the app uses Storage for is the cold archive of project data
// (completed / weekly history / deleted), stored as JSON blobs under /archive.
// See src/utils/storageArchive.js. Image note attachments are NOT in Storage —
// they are Base64 inside Realtime Database (src/services/imageService.js).
service firebase.storage {
  match /b/{bucket}/o {

    // Cold archive: any signed-in user of the app may read/write.
    // NOTE: Storage rules cannot read the RTDB user profile, so this can't be
    // narrowed to "approved" without custom claims. `auth != null` already
    // removes the anonymous-internet access that the old separate, unauthenticated
    // backup project exposed — that was the actual hole being closed.
    match /archive/{file} {
      allow read, write: if request.auth != null;
    }

    // Nothing else uses Storage: deny everything else.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
